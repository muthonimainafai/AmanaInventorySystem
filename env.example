# Copy this file to `.env` in the same folder as server.js and set your own values.
# `.env` is gitignored — never commit real passwords.
#
# These values are used only when the database has NO users yet (first run).
# If you already have a data/inventory.db with users, delete that file to re-seed,
# or change passwords directly in the database.

# Owner (full Feed Inventory + retail + chicken inventory)
AMANA_OWNER_USERNAME=owner
AMANA_OWNER_PASSWORD=Owner@123
AMANA_OWNER_FULL_NAME=Shop Owner

# Staff (Sales Per Bags, Sales Per Kg, Chicken Sales)
AMANA_EMPLOYEE_USERNAME=employee
AMANA_EMPLOYEE_PASSWORD=Employee@123
AMANA_EMPLOYEE_FULL_NAME=Shop Employee

# Rose Inventory (separate tenant database + login)
ROSE_OWNER_USERNAME=owner
ROSE_OWNER_PASSWORD=Owner@123
ROSE_OWNER_FULL_NAME=Rose Owner
ROSE_EMPLOYEE_USERNAME=employee
ROSE_EMPLOYEE_PASSWORD=Employee@123
ROSE_EMPLOYEE_FULL_NAME=Rose Employee

# Nahah Feeds Inventory System (separate tenant database + login)
NAHAH_OWNER_USERNAME=owner
NAHAH_OWNER_PASSWORD=Owner@123
NAHAH_OWNER_FULL_NAME=Nahah Owner
NAHAH_EMPLOYEE_USERNAME=employee
NAHAH_EMPLOYEE_PASSWORD=Employee@123
NAHAH_EMPLOYEE_FULL_NAME=Nahah Employee

# Nahah workspace: Terry (separate tenant database + login)
TERRY_OWNER_USERNAME=owner
TERRY_OWNER_PASSWORD=Owner@123
TERRY_OWNER_FULL_NAME=Terry Owner
TERRY_EMPLOYEE_USERNAME=employee
TERRY_EMPLOYEE_PASSWORD=Employee@123
TERRY_EMPLOYEE_FULL_NAME=Terry Employee

# Nahah workspace: Cess (separate tenant database + login)
CESS_OWNER_USERNAME=owner
CESS_OWNER_PASSWORD=Owner@123
CESS_OWNER_FULL_NAME=Cess Owner
CESS_EMPLOYEE_USERNAME=employee
CESS_EMPLOYEE_PASSWORD=Employee@123
CESS_EMPLOYEE_FULL_NAME=Cess Employee

# Nahah workspace: Shop (separate tenant database + login)
SHOP_OWNER_USERNAME=owner
SHOP_OWNER_PASSWORD=Owner@123
SHOP_OWNER_FULL_NAME=Shop Owner
SHOP_EMPLOYEE_USERNAME=employee
SHOP_EMPLOYEE_PASSWORD=Employee@123
SHOP_EMPLOYEE_FULL_NAME=Shop Employee

# Ufaray Feeds (separate tenant database + login)
UFARAY_OWNER_USERNAME=owner
UFARAY_OWNER_PASSWORD=Owner@123
UFARAY_OWNER_FULL_NAME=Ufaray Owner
UFARAY_EMPLOYEE_USERNAME=employee
UFARAY_EMPLOYEE_PASSWORD=Employee@123
UFARAY_EMPLOYEE_FULL_NAME=Ufaray Employee

# Strongly recommended for production (signing login tokens)
# JWT_SECRET=use-a-long-random-string-here
